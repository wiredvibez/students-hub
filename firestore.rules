rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function to check if current user is admin
    function isAdmin() {
      return request.auth != null 
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.admin == true;
    }

    // Users collection
    match /users/{userId} {
      // Anyone authenticated can read all users (for leaderboard)
      allow read: if request.auth != null;
      // Users can only create/update their own profile
      allow create, update: if request.auth != null && request.auth.uid == userId;

      // User's answers subcollection
      match /answers/{answerId} {
        allow read, create: if request.auth != null && request.auth.uid == userId;
      }
    }

    // Collection group read for notes queries (e.g. user's notes page via client)
    match /{path=**}/notes/{noteId} {
      allow read: if request.auth != null
        && resource.data.createdBy == request.auth.uid;
    }

    // Questions collection
    match /questions/{questionId} {
      // Anyone authenticated can read questions
      allow read: if request.auth != null;
      // Anyone authenticated can create questions
      allow create: if request.auth != null;
      // Anyone authenticated can update only ratings, avgRating, and timesAnswered
      allow update: if request.auth != null
        && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(["ratings", "avgRating", "timesAnswered"]);
      // Only admins can delete questions
      allow delete: if isAdmin();

      // Buddy notes subcollection (one note per user — doc id = user uid)
      match /notes/{noteId} {
        allow read: if request.auth != null;

        allow create: if request.auth != null
          && request.auth.uid == noteId
          && request.resource.data.createdBy == request.auth.uid
          && request.resource.data.questionId == questionId
          && request.resource.data.displayName == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.displayName
          && request.resource.data.text is string
          && request.resource.data.text.size() > 0
          && request.resource.data.text.size() <= 500
          && request.resource.data.score == 0
          && request.resource.data.upvotes == 0
          && request.resource.data.downvotes == 0;

        allow update: if request.auth != null
          && request.auth.uid == noteId
          && request.resource.data.diff(resource.data).affectedKeys()
              .hasOnly(["text", "updatedAt"])
          && request.resource.data.text is string
          && request.resource.data.text.size() > 0
          && request.resource.data.text.size() <= 500;

        allow delete: if false;

        match /votes/{voterId} {
          allow read: if request.auth != null;
          allow create, update, delete: if false;
        }
      }
    }
  }
}
