# Copy to .env.local for local dev, or add in Vercel → Project Settings → Environment Variables
# https://vercel.com/yairs-projects-d2943395/students-hub/settings/environment-variables

# Firebase client (public — safe for browser)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Firebase Admin (server-only — for /api/openai auth verification)
FIREBASE_ADMIN_CLIENT_EMAIL=
# Paste the full private key; Vercel accepts literal newlines or \n escapes
FIREBASE_ADMIN_PRIVATE_KEY=

# OpenAI (server-only — for AI question formatting)
OPENAI_API_KEY=
